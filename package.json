{
  "name": "arachne",
  "version": "0.1.0",
  "description": "AI runtime control plane - provider-agnostic OpenAI-compatible proxy",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx scripts/backfill-sandbox-keys.ts && node dist/index.js",
    "migrate": "node-pg-migrate",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "test": "vitest run --project arachne --project loom-portal",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run --project smoke",
    "test:smoke:live": "npm run test:smoke && npm run smoke:cleanup",
    "seed": "tsx scripts/seed.ts",
    "smoke:cleanup": "tsx scripts/cleanup-smoke-data.ts",
    "build:portal": "cd portal && npm run build",
    "build:all": "npm run build:portal && cd dashboard && npm run build",
    "docs:screenshots": "DOCS_MODE=true vitest run --config vitest.smoke.config.ts",
    "docs:generate": "tsx scripts/generate-ui-docs.ts",
    "docs:build": "npm run docs:screenshots && npm run docs:generate",
    "backfill:sandbox-keys": "tsx scripts/backfill-sandbox-keys.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "changeset publish"
  },
  "keywords": [
    "ai",
    "proxy",
    "openai",
    "audit",
    "observability"
  ],
  "author": "Michael Brown",
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.11",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^28.1.0",
    "playwright": "^1.49.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@mikro-orm/better-sqlite": "^6.6.7",
    "@mikro-orm/core": "^6.6.7",
    "@mikro-orm/migrations": "^6.6.7",
    "@mikro-orm/postgresql": "^6.6.7",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "undici": "^7.22.0"
  },
  "engines": {
    "node": ">=25.2.1"
  },
  "main": "index.js",
  "workspaces": [
    "cli",
    "packages/chat",
    "site"
  ]
}
