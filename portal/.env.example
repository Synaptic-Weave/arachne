# API base URL for the Arachne backend.
# Leave empty to use relative URLs (same-origin, default for development).
# Set to the full gateway URL for production builds, e.g. https://api.arachne-ai.com
VITE_API_BASE_URL=

# Set to true to enable public account creation. Default is false (beta: waitlist-only).
VITE_ALLOW_SIGNUPS=false
