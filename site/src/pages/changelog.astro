---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

// Read CHANGELOG.md from the repo root and convert to HTML
let changelogHtml = '<p>No changelog available yet.</p>';
try {
  const raw = readFileSync(join(process.cwd(), '..', 'CHANGELOG.md'), 'utf-8');
  // Strip the top-level heading
  const content = raw.replace(/^# .+\n/, '');
  // Simple markdown → HTML conversion for changelog format
  changelogHtml = content
    // Headers
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    // Bold
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    // Inline code
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    // List items
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    // Horizontal rules
    .replace(/^---$/gm, '<hr />')
    // Wrap consecutive <li> in <ul>
    .replace(/((?:<li>.*<\/li>\n?)+)/g, '<ul>$1</ul>')
    // Paragraphs (non-empty lines that aren't already tags)
    .replace(/^(?!<[hulo]|<li|<hr)(.+)$/gm, '<p>$1</p>')
    // Clean up empty lines
    .replace(/\n{2,}/g, '\n');
} catch {
  // Keep default
}
---

<BaseLayout title="Changelog — Arachne" description="Release history and version notes.">
  <div class="max-w-3xl mx-auto px-4 sm:px-8 py-16">
    <h1 class="text-3xl font-bold text-white mb-2">Changelog</h1>
    <p class="text-gray-400 mb-10">Release history and version notes.</p>
    <div class="prose-dark" set:html={changelogHtml} />
  </div>
</BaseLayout>
