---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

// Read CHANGELOG.md from the repo root
let changelogContent = '';
try {
  changelogContent = readFileSync(join(process.cwd(), '..', 'CHANGELOG.md'), 'utf-8');
} catch {
  changelogContent = 'No changelog available yet.';
}
---

<BaseLayout title="Changelog — Arachne" description="Release history and version notes.">
  <div class="max-w-3xl mx-auto px-4 sm:px-8 py-16">
    <h1 class="text-3xl font-bold text-white mb-2">Changelog</h1>
    <p class="text-gray-400 mb-10">Release history and version notes.</p>
    <div class="prose-dark" set:html={changelogContent.replace(/^# .+\n/, '')} />
  </div>
</BaseLayout>
