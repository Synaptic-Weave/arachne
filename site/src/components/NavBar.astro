---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/docs/getting-started', label: 'Docs' },
  { href: '/developers/api-reference', label: 'Developers' },
  { href: '/blog', label: 'Blog' },
  { href: '/changelog', label: 'Changelog' },
];
---

<header class="border-b border-gray-800">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-4 sm:px-8 py-4">
    <a href="/" class="text-xl font-bold tracking-tight hover:text-white transition-colors">
      <span class="text-gray-400">&#x29D6;</span> Arachne
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm transition-colors',
            currentPath.startsWith(link.href.split('/').slice(0, 2).join('/'))
              ? 'text-white font-medium'
              : 'text-gray-400 hover:text-gray-100',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://app.arachne-ai.com/login"
        class="text-sm text-gray-400 hover:text-gray-100 transition-colors"
      >
        Sign in
      </a>
      <a
        href="#beta-signup"
        class="text-sm px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg transition-colors"
      >
        Join the Beta
      </a>
    </div>
  </div>
</header>
