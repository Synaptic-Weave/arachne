    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
      <div>
        <h4 class="text-sm font-semibold text-gray-200 mb-3">Product</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/docs/getting-started" class="hover:text-gray-200">Getting Started</a></li>
          <li><a href="/docs/portal-guide" class="hover:text-gray-200">Portal Guide</a></li>
          <li><a href="/docs/cli-quickstart" class="hover:text-gray-200">CLI</a></li>
          <li><a href="/docs/chat-widget" class="hover:text-gray-200">Chat Widget</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-gray-200 mb-3">Developers</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/developers/api-reference" class="hover:text-gray-200">API Reference</a></li>
          <li><a href="/developers/architecture" class="hover:text-gray-200">Architecture</a></li>
          <li><a href="/developers/rag-inference" class="hover:text-gray-200">RAG Inference</a></li>
