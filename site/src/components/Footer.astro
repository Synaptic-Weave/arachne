          <li><a href="/blog" class="hover:text-gray-200">Blog</a></li>
          <li><a href="/changelog" class="hover:text-gray-200">Changelog</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-gray-200 mb-3">Company</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/about" class="hover:text-gray-200">About</a></li>
